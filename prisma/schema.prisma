generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  username        String         @unique
  password        String
  name            String
  role            String         @default("cashier") // admin, cashier
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  sku         String      @unique
  price       Decimal     @db.Decimal(10, 2)
  stock       Int
  minStock    Int         @map("min_stock")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  saleItems   SaleItem[]

  @@map("products")
  @@index([sku])
  @@index([name])
}

model CashRegister {
  id            String    @id @default(uuid())
  openingAmount Decimal   @db.Decimal(10, 2) @map("opening_amount")
  closingAmount Decimal?  @db.Decimal(10, 2) @map("closing_amount")
  status        String    @default("open") // open, closed
  openedBy      String    @map("opened_by")
  closedBy      String?   @map("closed_by")
  openedAt      DateTime  @default(now()) @map("opened_at")
  closedAt      DateTime? @map("closed_at")
  sales         Sale[]
  expenses      Expense[]

  @@map("cash_registers")
}

model Expense {
  id             String       @id @default(uuid())
  amount         Decimal      @db.Decimal(10, 2)
  description    String
  paymentMethod  String       @default("cash") @map("payment_method")
  createdBy      String       @map("created_by")
  cashRegisterId String       @map("cash_register_id")
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("expenses")
  @@index([cashRegisterId])
}

model Sale {
  id              String         @id @default(uuid())
  total           Decimal        @db.Decimal(10, 2)
  paymentMethod   String         @default("cash") @map("payment_method")
  cashRegisterId  String?        @map("cash_register_id")
  items           SaleItem[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  cashRegister    CashRegister?  @relation(fields: [cashRegisterId], references: [id])

  @@map("sales")
  @@index([cashRegisterId])
}

model SaleItem {
  id          String   @id @default(uuid())
  saleId      String   @map("sale_id")
  productId   String   @map("product_id")
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2) @map("unit_price")
  subtotal    Decimal  @db.Decimal(10, 2)
  
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@map("sale_items")
  @@index([saleId])
  @@index([productId])
}